# =============================================================================
# LinkedIn-as-a-Service — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- Environment ---
ENVIRONMENT=development  # development | staging | production

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=linkedin_saas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_local_only
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- LinkedIn OAuth ---
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/linkedin/callback
LINKEDIN_SCOPES=openid,profile,email,w_member_social

# --- JWT ---
JWT_SECRET_KEY=change_this_to_a_random_64_char_string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# --- Encryption (Fernet) ---
FERNET_KEY=generate_with_python_cryptography_fernet_generate_key

# --- AI Engine ---
AI_ENGINE_URL=http://localhost:8001
AI_ENGINE_API_KEY=change_this_internal_microservice_key

# --- LLM ---
OPENAI_API_KEY=sk-your-openai-key
LLM_MODEL_STAGING=gpt-4o-mini
LLM_MODEL_PRODUCTION=gpt-4o
LLM_TIMEOUT_SECONDS=15
LLM_MAX_RETRIES=3

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=INFO
